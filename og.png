<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="630" viewBox="0 0 1200 630">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#0f1a14"/>
      <stop offset="100%" stop-color="#1a2820"/>
    </linearGradient>
    <linearGradient id="glow" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#1a6b4a" stop-opacity="0.4"/>
      <stop offset="100%" stop-color="#1a6b4a" stop-opacity="0"/>
    </linearGradient>
  </defs>

  <!-- Background -->
  <rect width="1200" height="630" fill="url(#bg)"/>

  <!-- Subtle glow top-left -->
  <ellipse cx="200" cy="150" rx="350" ry="250" fill="url(#glow)"/>

  <!-- Top accent line -->
  <rect x="0" y="0" width="1200" height="3" fill="#1a6b4a"/>

  <!-- Logo mark -->
  <rect x="72" y="72" width="52" height="52" rx="12" fill="#1a6b4a"/>
  <rect x="83" y="83" width="12" height="12" rx="2.5" fill="white"/>
  <rect x="101" y="83" width="12" height="12" rx="2.5" fill="white" opacity="0.6"/>
  <rect x="83" y="101" width="12" height="12" rx="2.5" fill="white" opacity="0.6"/>
  <rect x="101" y="101" width="12" height="12" rx="2.5" fill="white" opacity="0.3"/>

  <!-- Brand name -->
  <text x="138" y="109" font-family="Georgia, serif" font-size="36" font-weight="700" fill="white">LetFlowUK</text>

  <!-- Main headline -->
  <text x="72" y="230" font-family="Georgia, serif" font-size="68" font-weight="700" fill="white">HMO management</text>
  <text x="72" y="312" font-family="Georgia, serif" font-size="68" font-weight="700" fill="white">that <tspan fill="#4ade80" font-style="italic">actually</tspan> works</text>

  <!-- Subline -->
  <text x="72" y="376" font-family="'Helvetica Neue', Arial, sans-serif" font-size="26" fill="#9ca3af" letter-spacing="0.2">Track rent · Split bills · Stay compliant · No spreadsheets</text>

  <!-- Feature pills row -->
  <!-- Pill 1 -->
  <rect x="72" y="420" width="190" height="42" rx="21" fill="#1a6b4a" opacity="0.25"/>
  <rect x="72" y="420" width="190" height="42" rx="21" fill="none" stroke="#1a6b4a" stroke-width="1.5"/>
  <text x="167" y="447" font-family="'Helvetica Neue', Arial, sans-serif" font-size="17" fill="#4ade80" text-anchor="middle">Rent per room</text>
  <!-- Pill 2 -->
  <rect x="276" y="420" width="200" height="42" rx="21" fill="#1a6b4a" opacity="0.25"/>
  <rect x="276" y="420" width="200" height="42" rx="21" fill="none" stroke="#1a6b4a" stroke-width="1.5"/>
  <text x="376" y="447" font-family="'Helvetica Neue', Arial, sans-serif" font-size="17" fill="#4ade80" text-anchor="middle">RRA 2025 ready</text>
  <!-- Pill 3 -->
  <rect x="490" y="420" width="210" height="42" rx="21" fill="#1a6b4a" opacity="0.25"/>
  <rect x="490" y="420" width="210" height="42" rx="21" fill="none" stroke="#1a6b4a" stroke-width="1.5"/>
  <text x="595" y="447" font-family="'Helvetica Neue', Arial, sans-serif" font-size="17" fill="#4ade80" text-anchor="middle">Tenant portal</text>
  <!-- Pill 4 -->
  <rect x="714" y="420" width="240" height="42" rx="21" fill="#1a6b4a" opacity="0.25"/>
  <rect x="714" y="420" width="240" height="42" rx="21" fill="none" stroke="#1a6b4a" stroke-width="1.5"/>
  <text x="834" y="447" font-family="'Helvetica Neue', Arial, sans-serif" font-size="17" fill="#4ade80" text-anchor="middle">Legal notices</text>
  <!-- Pill 5 -->
  <rect x="968" y="420" width="160" height="42" rx="21" fill="#1a6b4a" opacity="0.25"/>
  <rect x="968" y="420" width="160" height="42" rx="21" fill="none" stroke="#1a6b4a" stroke-width="1.5"/>
  <text x="1048" y="447" font-family="'Helvetica Neue', Arial, sans-serif" font-size="17" fill="#4ade80" text-anchor="middle">P&amp;L reports</text>

  <!-- Bottom bar -->
  <rect x="0" y="555" width="1200" height="75" fill="#111827" opacity="0.8"/>

  <!-- Free badge -->
  <rect x="72" y="574" width="130" height="38" rx="19" fill="#1a6b4a"/>
  <text x="137" y="598" font-family="'Helvetica Neue', Arial, sans-serif" font-size="16" font-weight="600" fill="white" text-anchor="middle">Free to start</text>

  <!-- Pro badge -->
  <rect x="216" y="574" width="165" height="38" rx="19" fill="#1a6b4a" opacity="0.2"/>
  <rect x="216" y="574" width="165" height="38" rx="19" fill="none" stroke="#1a6b4a" stroke-width="1.5"/>
  <text x="298" y="598" font-family="'Helvetica Neue', Arial, sans-serif" font-size="16" fill="#4ade80" text-anchor="middle">Pro from £19/mo</text>

  <!-- URL right side -->
  <text x="1128" y="598" font-family="'Helvetica Neue', Arial, sans-serif" font-size="22" font-weight="600" fill="#6b7280" text-anchor="end">letflowuk.com</text>
</svg>